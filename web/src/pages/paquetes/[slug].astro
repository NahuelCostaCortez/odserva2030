---
import Layout from '../../components/Layout.astro';
import SectionContent from '../../components/SectionContent.astro';
import { getCollection } from 'astro:content';
import viewerScriptUrl from '../../scripts/package-viewer.ts?url';

export async function getStaticPaths() {
  const entries = await getCollection('work-packages');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { pkg: entry }
  }));
}

const { pkg } = Astro.props;
const dataPath = pkg.data.dataPath;
const contentSections = pkg.data.sectionsIndex.filter(
  (section, index) =>
    index !== 0 && section.title.toLowerCase() !== 'índice'
);
---
<Layout title={`ODServa2030 · ${pkg.data.title}`}>
  <aside class="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-badge">{pkg.data.code} · Informe</div>
      <div class="sidebar-title">{pkg.data.title}</div>
      <div class="sidebar-meta">
        <span>{contentSections.length} secciones</span>
        <span>{pkg.data.counts.tables} tablas</span>
        <span>{pkg.data.counts.figures} figuras</span>
      </div>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section-label">Índice</div>
      {contentSections.map((section) => (
        <a 
          href={`#${section.slug}`} 
          class={`nav-item level-${Math.min(section.level, 3)}`}
        >
          {section.title}
        </a>
      ))}
      <div class="nav-divider"></div>
      <a href="/" class="nav-item back-nav">← Volver al inicio</a>
    </nav>
  </aside>

  <main class="main-content">
    <div class="doc-header">
      <div class="doc-kicker">Normativa Universitaria Española · 2024</div>
      <h1 class="doc-title">
        {pkg.data.title}
      </h1>
    </div>

    <div id="package-sections" data-package-path={dataPath}>
      {contentSections.map((section) => (
        <SectionContent section={section} />
      ))}
    </div>
  </main>
  
  <script type="module" src={viewerScriptUrl} defer></script>
</Layout>

<style>
  /* SIDEBAR */
  .sidebar {
    width: var(--sidebar-w);
    background: var(--green-deep);
    color: #e8f5ee;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    flex-shrink: 0;
    z-index: 100;
  }

  .sidebar-header {
    padding: 2rem 1.5rem 1.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    background: linear-gradient(160deg, #0f2820 0%, #1a3a2e 100%);
  }

  .sidebar-badge {
    display: inline-flex;
    background: var(--gold);
    color: var(--green-deep);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 2px;
    margin-bottom: 0.8rem;
  }

  .sidebar-title {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
    color: #ffffff;
    margin-bottom: 0.8rem;
  }

  .sidebar-meta {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    color: rgba(255,255,255,0.45);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .sidebar-meta span::before {
    content: '— ';
    color: var(--green-light);
    opacity: 0.5;
  }

  /* SIDEBAR NAV */
  .sidebar-nav {
    padding-bottom: 2rem;
  }

  .nav-section-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    padding: 1.2rem 1.5rem 0.4rem;
  }

  .nav-item {
    display: block;
    font-family: 'DM Sans', sans-serif;
    padding: 0.6rem 1.5rem;
    transition: all 0.15s;
    border-left: 2px solid transparent;
    line-height: 1.4;
    text-decoration: none;
    color: inherit;
  }

  .nav-item.level-1 {
    font-weight: 500;
    color: rgba(255,255,255,0.85);
    text-transform: uppercase;
    font-size: 0.68rem;
    letter-spacing: 0.06em;
  }

  .nav-item.level-2 {
    padding-left: 2.2rem;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.65);
  }

  .nav-item.level-3 {
    padding-left: 3rem;
    font-size: 0.73rem;
    color: rgba(255,255,255,0.45);
  }

  .nav-item:hover {
    color: #ffffff;
    background: rgba(255,255,255,0.05);
    border-left: 2px solid var(--green-light);
  }

  .nav-item.back-nav {
    margin-top: 0.5rem;
    color: var(--green-light);
    opacity: 0.7;
    font-size: 0.75rem;
  }

  .nav-item.back-nav:hover {
    opacity: 1;
    background: transparent;
    border-left-color: transparent;
    text-decoration: underline;
  }

  .nav-divider {
    height: 1px;
    background: rgba(255,255,255,0.07);
    margin: 0.8rem 1.5rem;
  }

  /* Custom scrollbar for sidebar */
  .sidebar::-webkit-scrollbar { width: 4px; }
  .sidebar::-webkit-scrollbar-thumb {
    background: rgba(255,255,255,0.15);
    border-radius: 2px;
  }

  /* MAIN CONTENT HEADER */
  .doc-header {
    padding-bottom: 2.5rem;
    margin-bottom: 3.5rem;
    border-bottom: 2px solid var(--green-deep);
    position: relative;
  }

  .doc-header::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 80px;
    height: 2px;
    background: var(--gold);
  }

  .doc-kicker {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--green-accent);
    margin-bottom: 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .doc-kicker::before {
    content: '';
    display: block;
    width: 20px;
    height: 1px;
    background: var(--green-accent);
  }

  .doc-title {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--green-deep);
    max-width: 650px;
    margin: 0;
  }

  @media (max-width: 800px) {
    .sidebar {
      display: none;
    }
  }
</style>
