---
const { title = 'ODServa2030', description = 'Observatorio de implementación de la Agenda 2030' } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        color-scheme: light;
        font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #f5f5fb;
        color: #1f2933;
      }
      *, *::before, *::after {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        min-height: 100vh;
        background: var(--surface, #f5f5fb);
      }
      a {
        color: #1d4ed8;
        text-decoration: none;
      }
      main {
        width: 100%;
        padding: 2.5rem 4vw 4rem;
      }
      header.site-header {
        padding: 1.5rem 4vw 0;
        width: 100%;
      }
      .site-title {
        font-weight: 600;
        font-size: 1.6rem;
        margin-bottom: 0.25rem;
      }
      .site-subtitle {
        color: #4b5563;
        font-size: 0.95rem;
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="site-title">Observatorio Agenda 2030</div>
      <div class="site-subtitle">Sistema Universitario Español · ODServa2030</div>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
