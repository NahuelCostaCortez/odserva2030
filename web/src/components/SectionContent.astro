---
const { section } = Astro.props;
const levelClass = `level-${section.level}`;
---
<section id={section.slug} class={`section ${levelClass}`} data-section-block={section.id} data-level={section.level}>
  {section.level === 2 && (
    <div class="section-heading">
      <div class="section-heading-bar"></div>
      <h2 class="section-title">{section.title}</h2>
    </div>
  )}

  {section.level === 3 && (
    <h3 class="subsection-title">{section.title}</h3>
  )}

  {section.level === 1 && (
    <h2 class="section-level-1-title">{section.title}</h2>
  )}

  <div class="section-content" data-section-content></div>
  <div class="section-tables" data-section-tables></div>
  <div class="section-figures" data-section-figures></div>
</section>

<style>
  .section {
    margin-bottom: 3.5rem;
    max-width: 860px;
  }

  /* H2 - Section Heading (Kicker) */
  .section-heading {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }

  .section-heading-bar {
    width: 4px;
    height: 1.6rem;
    background: linear-gradient(to bottom, var(--green-accent), var(--green-light));
    border-radius: 2px;
    flex-shrink: 0;
  }

  .section-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--green-accent);
    margin: 0;
  }

  /* H3 - Subsection Title */
  .subsection-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--green-deep);
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
  }

  /* Level 1 fallback title */
  .section-level-1-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--green-deep);
    margin-bottom: 2rem;
  }

  /* Content typography */
  .section-content {
    font-family: 'Source Serif 4', serif;
    font-size: 0.95rem;
    line-height: 1.85;
    color: var(--ink-mid);
    font-weight: 300;
  }

  .section-content :global(p) {
    margin-bottom: 1.2rem;
  }

  .section-content :global(strong) {
    font-weight: 600;
    color: var(--ink);
  }

  /* Animation delays */
  .section:nth-child(2) { animation-delay: 0.05s; }
  .section:nth-child(3) { animation-delay: 0.10s; }
  .section:nth-child(4) { animation-delay: 0.15s; }
  .section:nth-child(n+5) { animation-delay: 0.20s; }
</style>

<style is:global>
  /* PULL QUOTE (standard blockquote) */
  blockquote {
    border-left: 3px solid var(--gold);
    padding: 1rem 1.5rem;
    margin: 2rem 0;
    background: var(--paper);
    border-radius: 0 4px 4px 0;
  }

  blockquote p {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 1.05rem;
    color: var(--green-deep) !important;
    margin: 0 !important;
    line-height: 1.6 !important;
  }

  /* ODS TAGS */
  .ods-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 1.5rem 0;
  }

  .ods-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.65rem;
    font-weight: 500;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    border: 1px solid;
    display: inline-block;
  }

  .ods-tag.t1 { background: #fff3e0; color: #e65100; border-color: #ffcc80; }
  .ods-tag.t2 { background: #e8f5e green; color: #2e7d32; border-color: #a5d6a7; }
  .ods-tag.t3 { background: #e3f2fd; color: #1565c0; border-color: #90caf9; }
  .ods-tag.t4 { background: #fce4ec; color: #ad1457; border-color: #f48fb1; }

  /* NIVEL CARDS */
  .nivel-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 2rem 0;
  }

  .nivel-card {
    display: flex;
    gap: 1rem;
    padding: 1.1rem 1.3rem;
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 6px;
    border-left: 4px solid var(--green-accent);
    transition: box-shadow 0.2s;
  }

  .nivel-card:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  }

  .nivel-card:nth-child(2) { border-left-color: var(--gold); }
  .nivel-card:nth-child(3) { border-left-color: var(--green-mid); }

  .nivel-icon {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #ffffff;
    background: var(--green-accent);
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    height: fit-content;
    margin-top: 0.1rem;
    white-space: nowrap;
  }

  .nivel-card:nth-child(2) .nivel-icon {
    background: var(--gold);
    color: var(--green-deep);
  }

  .nivel-content h4 {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 0.3rem 0;
  }

  .nivel-content p {
    font-size: 0.83rem !important;
    line-height: 1.6 !important;
    margin: 0 !important;
    color: var(--ink-soft) !important;
  }

  /* TABLES */
  .table-block {
    margin: 2rem 0;
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }

  .table-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--ink-soft);
    padding: 0.8rem 1.2rem;
    background: var(--paper);
    border-bottom: 1px solid var(--border);
    margin: 0;
  }

  .table-wrapper {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
  }

  th, td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    text-align: left;
  }

  th {
    background: #fafafa;
    font-weight: 500;
    color: var(--ink);
    text-transform: uppercase;
    font-size: 0.65rem;
    letter-spacing: 0.05em;
  }

  tbody tr:last-child td {
    border-bottom: none;
  }

  /* FIGURES */
  figure {
    margin: 2rem 0;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    background: #ffffff;
  }

  figure img {
    width: 100%;
    display: block;
  }

  figcaption {
    padding: 0.8rem 1.2rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.73rem;
    color: var(--ink-soft);
    font-style: italic;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .page-chip {
    font-style: normal;
    font-weight: 500;
    color: var(--green-accent);
  }
</style>